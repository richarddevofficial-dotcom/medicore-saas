# Copy to backend/.env and fill in real values.
# Gmail example: use an App Password (not your normal account password).

# Django core security settings
DJANGO_SECRET_KEY=replace_with_a_long_random_secret
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
ENABLE_PASSWORD_VALIDATORS=false

# CORS (set CORS_ALLOW_ALL_ORIGINS=false in production)
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# HTTPS cookie/redirect settings (used when DEBUG=false)
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=drichigroup@gmail.com
EMAIL_HOST_PASSWORD=replace_with_gmail_app_password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=drichigroup@gmail.com
