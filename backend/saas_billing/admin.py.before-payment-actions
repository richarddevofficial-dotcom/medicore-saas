        "current_monthly_price",
    )

    list_filter = (
        "status",
        "plan",
        "service_fee_paid",
        "auto_renew",
    )

    search_fields = (
        "hospital__name",
        "hospital__slug",
        "hospital__email",
        "plan__name",
